#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

/ {
  keymap {
    compatible = "zmk,keymap";

    default_layer {
      bindings = <
        &kp C        &kp LEFT   &kp DOWN   &kp RIGHT  &kp V
        &kp K        &kp I      &kp UP     &kp P      &kp LC(M)
        &kp U        &kp F3     &kp W      &kp B      &kp O
        &kp A        &kp T      &kp Q      &kp S      &kp Y
      >;
    };
  };
};
